<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="校园电子商城"
        android:theme="@style/Theme.CampusShop">

        <!-- 启动页：登录 -->
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 注册 -->
        <activity android:name=".ui.register.RegisterActivity" />

        <!-- 主界面 -->
        <activity android:name=".ui.MainActivity" />

        <!-- 商品详情 -->
        <activity android:name=".ui.detail.GoodsDetailActivity" />

        <!-- 结算页 -->
        <activity android:name=".ui.checkout.CheckoutActivity" />

        <!-- 订单列表 -->
        <activity android:name=".ui.order.OrderListActivity" />

    </application>
</manifest>
